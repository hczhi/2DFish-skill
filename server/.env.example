PORT=3001
NODE_ENV=production

# 必填 — JWT 签名密钥，生产环境必须设置为随机字符串（≥32字符）
# 生成方法: openssl rand -base64 48
JWT_SECRET=change-this-to-a-random-string

# 可选 — 允许跨域的前端域名（逗号分隔）
# 方案A（Node统一服务，同源）下可不设置
# 方案B（Nginx分流，API和前端不同域）下必须设置
# 示例: CORS_ORIGIN=https://example.com,https://www.example.com
# CORS_ORIGIN=

# Platform LLM key is configured via Admin panel (stored in database)
